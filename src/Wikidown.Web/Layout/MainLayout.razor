@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" IsDarkMode="false" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@ToggleDrawer" />
        <MudLink Href="" Color="Color.Inherit" Underline="Underline.None" Class="ml-2 d-flex align-center">
            <img src="logo.png" alt="" height="28" style="margin-right:8px;" />
            <MudText Typo="Typo.h6">Wikidown</MudText>
        </MudLink>
        <MudSpacer />
        <div class="wd-appbar-slot d-flex align-center flex-grow-0">
            <SectionOutlet SectionName="appbar-actions" />
        </div>
        <MudSpacer />
        <DraftsMenu />
        <MudLink Href="https://github.com/markdav-is/Wikidown" Target="_blank"
                 Color="Color.Inherit" Underline="Underline.None">
            <MudIcon Icon="@Icons.Custom.Brands.GitHub" />
        </MudLink>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="1" ClipMode="DrawerClipMode.Always">
        <MudNavMenu>
            <MudNavLink Href="" Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Home">Home</MudNavLink>
            <MudNavLink Href="connect" Icon="@Icons.Material.Filled.Link">Connect</MudNavLink>
            <MudNavLink Href="browse" Icon="@Icons.Material.Filled.MenuBook">Browse</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="py-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1f2a40",
            Secondary = "#1b6ec2",
            AppbarBackground = "#1f2a40",
        }
    };

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
