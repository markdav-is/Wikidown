@page "/browse"
@page "/browse/{*Path}"
@inject ConnectionStore Store
@inject BackendResolver Backends
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService Dialogs
@inject DraftStore Drafts
@using Wikidown.Core
@using Wikidown.Web.Services

<PageTitle>Browse — Wikidown</PageTitle>

@if (_conn is null)
{
    <MudText Typo="Typo.h4" GutterBottom="true">Browse</MudText>
    <MudAlert Severity="Severity.Info">
        No wiki connected. <MudLink Href="connect">Connect one</MudLink>.
    </MudAlert>
}
else
{
    <MudGrid Spacing="3">
        <MudItem xs="12" md="4" lg="3">
            <MudPaper Class="pa-3" Outlined="true">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.FolderOpen" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2">@RepoLabel(_conn)</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Default">@@@_conn.Branch · /@_conn.DocsPath</MudText>
                    </MudStack>
                </MudStack>

                @if (_loadingTree)
                {
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                }
                else if (_treeError is { } terr)
                {
                    <MudAlert Severity="Severity.Error" Dense="true">@terr</MudAlert>
                }
                else if (_pages.Count == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Default">
                        No pages found at <code>/@_conn.DocsPath</code>.
                    </MudText>
                }
                else
                {
                    <MudNavMenu Class="wd-tree">
                        @foreach (var p in _pages)
                        {
                            <MudNavLink Href="@($"browse{p.ToLinkPath()}")"
                                        Match="NavLinkMatch.All"
                                        Icon="@Icons.Material.Filled.Article">
                                @p.Name.Title
                            </MudNavLink>
                        }
                    </MudNavMenu>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="8" lg="9">
            @if (_currentPath is null)
            {
                <MudPaper Class="pa-6" Outlined="true">
                    <MudText Typo="Typo.h5">Pick a page</MudText>
                    <MudText>Choose a page from the tree to view or edit it.</MudText>
                </MudPaper>
            }
            else if (_loadingPage)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                    <MudText>Loading @_currentPath.ToLinkPath()…</MudText>
                </MudStack>
            }
            else if (_pageError is { } perr)
            {
                <MudText Typo="Typo.h4">@_currentPath.Name.Title</MudText>
                <MudAlert Severity="Severity.Error">@perr</MudAlert>
            }
            else if (_currentPage is { } loaded)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h4">@loaded.Path.Name.Title</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Default">@loaded.Path.ToLinkPath()</MudText>
                    </MudStack>
                    <MudSpacer />
                    <MudToggleIconButton Toggled="@_editMode" ToggledChanged="@OnToggleEdit"
                                         Icon="@Icons.Material.Filled.Edit" Color="@Color.Default"
                                         ToggledIcon="@Icons.Material.Filled.Visibility"
                                         ToggledColor="@Color.Primary"
                                         title="Toggle edit mode" />
                </MudStack>

                @if (_editMode)
                {
                    <SectionContent SectionName="appbar-actions">
                        <MudTextField T="string" @bind-Value="_commitMessage"
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Placeholder="Commit message"
                                      Class="wd-appbar-commit mr-2" />
                        <MudButton Variant="Variant.Filled" Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.Save"
                                   Disabled="@(!HasChanges || _saving)"
                                   OnClick="SaveAsync">
                            @(_saving ? "Saving…" : "Save")
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Inherit"
                                   OnClick="DiscardDraft"
                                   Disabled="@(!HasChanges || _saving)"
                                   Class="ml-2">
                            Reset
                        </MudButton>
                        @if (HasChanges)
                        {
                            <MudChip T="string" Color="Color.Warning" Size="Size.Small"
                                     Icon="@Icons.Material.Filled.Edit" Class="ml-2">
                                Unsaved
                            </MudChip>
                        }
                    </SectionContent>
                    <MudGrid Spacing="2">
                        @if (_draftRestored)
                        {
                            <MudItem xs="12">
                                <MudAlert Severity="Severity.Info" ShowCloseIcon="true"
                                          CloseIconClicked="@(() => _draftRestored = false)">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                        <MudText>Restored an unsaved draft from this device.</MudText>
                                        <MudSpacer />
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined"
                                                   OnClick="DiscardDraft">
                                            Use remote
                                        </MudButton>
                                    </MudStack>
                                </MudAlert>
                            </MudItem>
                        }
                        <MudItem xs="12" md="6">
                            <MudPaper Outlined="true" Class="pa-2 wd-editor-pane">
                                <MudTextField Value="@_draft" ValueChanged="OnDraftChanged"
                                              T="string" Variant="Variant.Outlined"
                                              Lines="20" FullWidth="true" AutoGrow="false"
                                              Label="Markdown"
                                              InputMode="@InputMode.text"
                                              DebounceInterval="200" />
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudPaper Outlined="true" Class="pa-3 wd-preview-pane wd-page-md">
                                <MudMarkdown Value="@_draft" />
                            </MudPaper>
                        </MudItem>
                        @if (_conflictMessage is { } conflict)
                        {
                            <MudItem xs="12">
                                <MudAlert Severity="Severity.Warning" ShowCloseIcon="true"
                                          CloseIconClicked="@(() => _conflictMessage = null)">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                        <MudText>@conflict</MudText>
                                        <MudSpacer />
                                        <MudButton Size="Size.Small" Variant="Variant.Filled"
                                                   Color="Color.Warning" OnClick="ReloadFromRemote">
                                            Reload remote
                                        </MudButton>
                                    </MudStack>
                                </MudAlert>
                            </MudItem>
                        }
                    </MudGrid>
                }
                else
                {
                    <MudPaper Outlined="true" Class="pa-4 wd-page-md">
                        <MudMarkdown Value="@loaded.Markdown" />
                    </MudPaper>
                }
            }
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public string? Path { get; set; }

    private WikiConnection? _conn;
    private IReadOnlyList<PagePath> _pages = Array.Empty<PagePath>();
    private bool _loadingTree;
    private string? _treeError;

    private PagePath? _currentPath;
    private RemotePage? _currentPage;
    private bool _loadingPage;
    private string? _pageError;

    private bool _editMode;
    private string _draft = string.Empty;
    private string _commitMessage = string.Empty;
    private bool _saving;
    private string? _conflictMessage;
    private bool _draftRestored;

    private bool HasChanges =>
        _currentPage is { } p && !string.Equals(_draft, p.Markdown, StringComparison.Ordinal);

    protected override async Task OnInitializedAsync()
    {
        _conn = await Store.LoadAsync();
        if (_conn is not null) await LoadTreeAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_conn is null) return;
        var parsed = string.IsNullOrEmpty(Path) ? null : PagePath.Parse("/" + Path);
        if (Equals(parsed, _currentPath)) return;
        _currentPath = parsed;
        _editMode = false;
        _conflictMessage = null;
        _draftRestored = false;
        await LoadPageAsync();
    }

    private async Task LoadTreeAsync()
    {
        if (_conn is null) return;
        _loadingTree = true;
        _treeError = null;
        try
        {
            var backend = Backends.For(_conn.Provider);
            _pages = await backend.WalkAsync(_conn);
        }
        catch (Exception ex)
        {
            _treeError = $"Tree load failed: {ex.Message}";
            _pages = Array.Empty<PagePath>();
        }
        finally
        {
            _loadingTree = false;
        }
    }

    private async Task LoadPageAsync()
    {
        if (_conn is null || _currentPath is null) { _currentPage = null; _draft = string.Empty; return; }
        _loadingPage = true;
        _pageError = null;
        _currentPage = null;
        _draftRestored = false;
        try
        {
            var backend = Backends.For(_conn.Provider);
            _currentPage = await backend.ReadPageAsync(_conn, _currentPath);

            var saved = await Drafts.LoadAsync(_conn, _currentPath);
            if (saved is not null && !string.Equals(saved, _currentPage.Markdown, StringComparison.Ordinal))
            {
                _draft = saved;
                _draftRestored = true;
                _editMode = true;
            }
            else
            {
                _draft = _currentPage.Markdown;
            }
            _commitMessage = $"Update {_currentPath.Name.Title}";
        }
        catch (Exception ex)
        {
            _pageError = ex.Message;
        }
        finally
        {
            _loadingPage = false;
        }
    }

    private async Task OnDraftChanged(string value)
    {
        _draft = value;
        if (_conn is null || _currentPath is null || _currentPage is null) return;
        if (string.Equals(_draft, _currentPage.Markdown, StringComparison.Ordinal))
        {
            await Drafts.ClearAsync(_conn, _currentPath);
        }
        else
        {
            await Drafts.SaveAsync(_conn, _currentPath, _draft);
        }
    }

    private void OnToggleEdit(bool value)
    {
        _editMode = value;
        _conflictMessage = null;
        if (_editMode && _currentPage is { } p)
        {
            if (string.IsNullOrEmpty(_draft)) _draft = p.Markdown;
            if (string.IsNullOrWhiteSpace(_commitMessage) && _currentPath is not null)
                _commitMessage = $"Update {_currentPath.Name.Title}";
        }
    }

    private async Task DiscardDraft()
    {
        if (_currentPage is { } p) _draft = p.Markdown;
        _conflictMessage = null;
        _draftRestored = false;
        if (_conn is not null && _currentPath is not null)
            await Drafts.ClearAsync(_conn, _currentPath);
    }

    private async Task SaveAsync()
    {
        if (_conn is null || _currentPath is null || _currentPage is null) return;
        if (!HasChanges) return;

        _saving = true;
        _conflictMessage = null;
        try
        {
            var backend = Backends.For(_conn.Provider);
            var msg = string.IsNullOrWhiteSpace(_commitMessage)
                ? $"Update {_currentPath.Name.Title}"
                : _commitMessage.Trim();
            var result = await backend.WritePageAsync(_conn, new CommitRequest(
                _currentPath, _draft, _currentPage.Sha, msg));

            _currentPage = _currentPage with { Markdown = _draft, Sha = result.NewSha };
            await Drafts.ClearAsync(_conn, _currentPath);
            _draftRestored = false;
            Snackbar.Add($"Saved {_currentPath.Name.Title}", Severity.Success);
        }
        catch (WikiConflictException conflict)
        {
            _conflictMessage = conflict.Message;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ReloadFromRemote()
    {
        var keep = _draft;
        await LoadPageAsync();
        // Keep the user's pending edits in the editor so they can hand-merge.
        _draft = keep;
        _conflictMessage = null;
    }

    private static string RepoLabel(WikiConnection c) => c.Provider switch
    {
        WikiProvider.AzureDevOps => $"{c.Owner}/{c.Project}/{c.Repo}",
        _ => $"{c.Owner}/{c.Repo}",
    };
}
