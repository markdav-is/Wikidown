@page "/connect"

<PageTitle>Connect — Wikidown</PageTitle>

<h1>Connect a wiki</h1>

<p>Pick where your <code>/docs</code> lives. Wiring comes in later chunks.</p>

<div class="provider-grid">
    <div class="provider-card">
        <h2>GitHub</h2>
        <p>Sign in via Device Flow, or paste a Personal Access Token.</p>
        <button class="btn btn-secondary" disabled>Coming in chunk 4b</button>
    </div>
    <div class="provider-card">
        <h2>Azure DevOps</h2>
        <p>Paste an ADO Personal Access Token.</p>
        <button class="btn btn-secondary" disabled>Coming in chunk 4c</button>
    </div>
</div>
