@page "/connect"
@inject ConnectionStore Store
@inject NavigationManager Nav
@using Wikidown.Web.Services

<PageTitle>Connect — Wikidown</PageTitle>

<h1>Connect a wiki</h1>

<p>Your token stays in this browser (<code>localStorage</code>). No backend.</p>

@if (Store.Current is { } existing)
{
    <div class="alert alert-info">
        <strong>Connected:</strong> @existing.Display
        <button class="btn btn-sm btn-outline-secondary ms-3" @onclick="DisconnectAsync">Disconnect</button>
        <a class="btn btn-sm btn-primary ms-2" href="browse">Browse</a>
    </div>
}

<h2>GitHub</h2>
<p>
    Paste a <a target="_blank" rel="noopener" href="https://github.com/settings/tokens?type=beta">fine-grained Personal Access Token</a>
    scoped to the repo that holds your <code>/docs</code> folder, with
    <em>Contents: Read &amp; Write</em>.
</p>
<p class="text-muted small">
    Full GitHub OAuth (Device Flow) needs a small proxy because GitHub's
    <code>/login/device/code</code> endpoint blocks browser CORS. It's planned
    for a later chunk.
</p>

<form class="provider-form" @onsubmit="ConnectGitHubAsync" @onsubmit:preventDefault>
    <div class="mb-2">
        <label class="form-label" for="gh-owner">Owner</label>
        <input id="gh-owner" class="form-control" @bind="_ghOwner" placeholder="octocat" required />
    </div>
    <div class="mb-2">
        <label class="form-label" for="gh-repo">Repository</label>
        <input id="gh-repo" class="form-control" @bind="_ghRepo" placeholder="my-wiki" required />
    </div>
    <div class="row">
        <div class="col-sm-6 mb-2">
            <label class="form-label" for="gh-branch">Branch</label>
            <input id="gh-branch" class="form-control" @bind="_ghBranch" placeholder="main" required />
        </div>
        <div class="col-sm-6 mb-2">
            <label class="form-label" for="gh-docs">Docs path</label>
            <input id="gh-docs" class="form-control" @bind="_ghDocs" placeholder="docs" required />
        </div>
    </div>
    <div class="mb-2">
        <label class="form-label" for="gh-token">Personal access token</label>
        <input id="gh-token" type="password" class="form-control" @bind="_ghToken" required autocomplete="off" />
    </div>

    @if (_ghError is { } gerr)
    {
        <div class="alert alert-danger py-2">@gerr</div>
    }

    <button type="submit" class="btn btn-primary" disabled="@_ghBusy">
        @(_ghBusy ? "Connecting…" : "Connect")
    </button>
</form>

<h2 class="mt-4">Azure DevOps</h2>
<p>
    Use a <a target="_blank" rel="noopener" href="https://dev.azure.com">PAT</a>
    with <em>Code: Read &amp; Write</em> on the repo that holds your
    <code>/docs</code> folder.
</p>

<form class="provider-form" @onsubmit="ConnectAdoAsync" @onsubmit:preventDefault>
    <div class="row">
        <div class="col-sm-6 mb-2">
            <label class="form-label" for="ado-org">Organization</label>
            <input id="ado-org" class="form-control" @bind="_adoOrg" placeholder="contoso" required />
        </div>
        <div class="col-sm-6 mb-2">
            <label class="form-label" for="ado-project">Project</label>
            <input id="ado-project" class="form-control" @bind="_adoProject" placeholder="MyProject" required />
        </div>
    </div>
    <div class="mb-2">
        <label class="form-label" for="ado-repo">Repository</label>
        <input id="ado-repo" class="form-control" @bind="_adoRepo" placeholder="my-wiki" required />
    </div>
    <div class="row">
        <div class="col-sm-6 mb-2">
            <label class="form-label" for="ado-branch">Branch</label>
            <input id="ado-branch" class="form-control" @bind="_adoBranch" placeholder="main" required />
        </div>
        <div class="col-sm-6 mb-2">
            <label class="form-label" for="ado-docs">Docs path</label>
            <input id="ado-docs" class="form-control" @bind="_adoDocs" placeholder="docs" required />
        </div>
    </div>
    <div class="mb-2">
        <label class="form-label" for="ado-token">Personal access token</label>
        <input id="ado-token" type="password" class="form-control" @bind="_adoToken" required autocomplete="off" />
    </div>

    @if (_adoError is { } aerr)
    {
        <div class="alert alert-danger py-2">@aerr</div>
    }

    <button type="submit" class="btn btn-primary" disabled="@_adoBusy">
        @(_adoBusy ? "Connecting…" : "Connect")
    </button>
</form>

@code {
    private string _ghOwner = "";
    private string _ghRepo = "";
    private string _ghBranch = WikiConnection.DefaultBranch;
    private string _ghDocs = WikiConnection.DefaultDocsPath;
    private string _ghToken = "";
    private string? _ghError;
    private bool _ghBusy;

    private string _adoOrg = "";
    private string _adoProject = "";
    private string _adoRepo = "";
    private string _adoBranch = WikiConnection.DefaultBranch;
    private string _adoDocs = WikiConnection.DefaultDocsPath;
    private string _adoToken = "";
    private string? _adoError;
    private bool _adoBusy;

    protected override async Task OnInitializedAsync()
    {
        await Store.LoadAsync();
    }

    private async Task ConnectGitHubAsync()
    {
        _ghError = null;
        _ghBusy = true;
        try
        {
            var conn = new WikiConnection(
                WikiProvider.GitHub,
                _ghToken.Trim(),
                _ghOwner.Trim(),
                _ghRepo.Trim(),
                string.IsNullOrWhiteSpace(_ghBranch) ? WikiConnection.DefaultBranch : _ghBranch.Trim(),
                string.IsNullOrWhiteSpace(_ghDocs) ? WikiConnection.DefaultDocsPath : _ghDocs.Trim('/'));
            await Store.SaveAsync(conn);
            Nav.NavigateTo("browse");
        }
        catch (Exception ex)
        {
            _ghError = ex.Message;
        }
        finally
        {
            _ghBusy = false;
        }
    }

    private async Task ConnectAdoAsync()
    {
        _adoError = null;
        _adoBusy = true;
        try
        {
            var conn = new WikiConnection(
                WikiProvider.AzureDevOps,
                _adoToken.Trim(),
                _adoOrg.Trim(),
                _adoRepo.Trim(),
                string.IsNullOrWhiteSpace(_adoBranch) ? WikiConnection.DefaultBranch : _adoBranch.Trim(),
                string.IsNullOrWhiteSpace(_adoDocs) ? WikiConnection.DefaultDocsPath : _adoDocs.Trim('/'),
                _adoProject.Trim());
            await Store.SaveAsync(conn);
            Nav.NavigateTo("browse");
        }
        catch (Exception ex)
        {
            _adoError = ex.Message;
        }
        finally
        {
            _adoBusy = false;
        }
    }

    private async Task DisconnectAsync()
    {
        await Store.ClearAsync();
    }
}
